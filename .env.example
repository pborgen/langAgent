# Agent backend: "langgraph" (OpenAI) or "claude" (Anthropic)
AGENT_BACKEND=langgraph

# OpenAI (required when AGENT_BACKEND=langgraph)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Local / OpenAI-compatible LLM (optional).
# Set OPENAI_BASE_URL to point the langgraph backend at a local server such as
# Ollama, LM Studio, vLLM, or llama.cpp. When set, OPENAI_API_KEY is optional.
# Examples:
#   Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1  (OPENAI_MODEL=llama3.1)
#   LM Studio:   OPENAI_BASE_URL=http://localhost:1234/v1
#   vLLM local:  OPENAI_BASE_URL=http://localhost:8001/v1
#   vLLM remote: OPENAI_BASE_URL=http://100.99.15.47:8001/v1  (OPENAI_MODEL=Qwen/Qwen2.5-0.5B-Instruct)
OPENAI_BASE_URL=

# Anthropic (required when AGENT_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Knowledge base
USE_PINECONE=false
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_index_name
PINECONE_NAMESPACE=
EMBEDDING_MODEL=text-embedding-3-small
STRICT_STARTUP_VALIDATION=false

# Storage (SQLite database path; defaults to data/support.db)
DB_PATH=
