# Agent backend: "langgraph" (OpenAI) or "claude" (Anthropic)
AGENT_BACKEND=langgraph

# OpenAI (required when AGENT_BACKEND=langgraph)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (required when AGENT_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Knowledge base
USE_PINECONE=false
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_index_name
PINECONE_NAMESPACE=
EMBEDDING_MODEL=text-embedding-3-small
STRICT_STARTUP_VALIDATION=false

# Storage (SQLite database path; defaults to data/support.db)
DB_PATH=
