# === Model selection — uncomment exactly one ===
# Override at runtime with: ./docker_up.sh gpu <model-id>
#VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct      # ~1GB, ~30s startup, smoke tests
#VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct      # ~3GB, fast, light quality
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct         # ~14GB, prod-quality
VLLM_REQUIRE_AUTH=true
VLLM_API_KEY=change-me-vllm-key
PROXY_API_KEY=change-me-proxy-key
VLLM_PORT=8001
PROXY_PORT=8010
REDIS_PORT=6379
VLLM_DTYPE=auto
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.90
MEMORY_MAX_MESSAGES=20
REQUEST_TIMEOUT_SECONDS=120
HUGGING_FACE_HUB_TOKEN=
